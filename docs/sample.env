# WordPress Environment Configuration
# Copy to your WP root as .env (and optionally .env.local for overrides)
# Priority: OS env > .env.local > .env

# App environment: development | staging | production
APP_ENV=development

# Database
DB_NAME=wordpress
DB_USER=root
DB_PASSWORD=
DB_HOST=mysql

# Site URL (set for Docker/staging, leave empty for WP Settings values)
# WP_HOME_URL=https://your-site.com

# SMTP (uncomment and fill for email sending)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=you@gmail.com
# SMTP_PASS=app-password-here
